# --- Twitch (opzionale - stream data) ---
# TWITCH_CLIENT_ID=...
# TWITCH_CLIENT_SECRET=...

# --- Spotify (opzionale) ---
# SPOTIFY_CLIENT_ID=...
# SPOTIFY_CLIENT_SECRET=...
SAFE_MODE='true'
